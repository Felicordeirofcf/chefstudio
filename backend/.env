# Porta do servidor
PORT=3001

# MongoDB (para quando ativar o banco)
MONGODB_URI=mongodb://localhost:27017/chefia_studio_db

# JWT (para autenticação segura)
JWT_SECRET=sua_chave_super_secreta

# Outros tokens/API Keys se você estiver usando integração com Meta Ads ou outros serviços
META_ACCESS_TOKEN=coloque_aqui_seu_token
